# GCP
# Also used directly in docker-compose.yml to build each service's Artifact
# Registry image path: ${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${GCP_REPOSITORY}/<service>:latest
# Matches the path scripts/docker/build-images.sh pushes to.
GCP_PROJECT_ID=eva-packaging
GCP_REGION=us-east4
GCP_REPOSITORY=onboarding

# Bucket holding Terraform remote state (created by scripts/gcloud/bootstrap-project.sh).
# Defaults to <GCP_PROJECT_ID>-tf-state if left blank.
GCP_TF_STATE_BUCKET=onboarding-tf-state

# Auth / Gateway
FRONTEND_ORIGIN=http://localhost:4200

# Provisioning adapters
GITHUB_API_TOKEN=
GITHUB_ORG=
ATLASSIAN_API_KEY=
ATLASSIAN_ACCOUNT_EMAIL=

# Postgres
DATABASE_USER=default
DATABASE_PASSWORD=password

# Confluent
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Auth
JWT_SECRET=

# Observability
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
PROMETHEUS_URL=http://localhost:9093
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin